# Default network when no ?network= URL param is present ("mainnet" or "sepolia")
VITE_DEFAULT_NETWORK=mainnet

# Mainnet Configuration
VITE_MAINNET_API_URL=https://localhost:3001
VITE_MAINNET_WS_URL=ws://localhost:3001/ws
# VITE_MAINNET_RPC_URL=https://api.cartridge.gg/x/starknet/mainnet

# Sepolia Configuration
VITE_SEPOLIA_API_URL=https://localhost:3002
VITE_SEPOLIA_WS_URL=ws://localhost:3002/ws
# VITE_SEPOLIA_RPC_URL=https://api.cartridge.gg/x/starknet/sepolia
