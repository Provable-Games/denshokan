# VITE_MAINNET_NUMBER_GUESS_WS_URL=wss://number-guess-api.example.com/ws

# Sepolia Configuration
VITE_SEPOLIA_API_URL=https://localhost:3002
VITE_SEPOLIA_WS_URL=ws://localhost:3002/ws
