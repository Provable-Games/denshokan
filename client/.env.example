# Default network when no ?network= URL param is present ("mainnet" or "sepolia")
VITE_DEFAULT_NETWORK=mainnet

# Mainnet Configuration
VITE_MAINNET_API_URL=https://localhost:3001
VITE_MAINNET_WS_URL=ws://localhost:3001/ws
