# Denshokan Deployment Configuration

# Required: Profile from snfoundry.toml (default, sepolia, mainnet)
PROFILE=sepolia

# Required: Royalty receiver address
ROYALTY_RECEIVER=0x123...

# Optional: Royalty fraction in basis points (default: 250 = 2.5%)
ROYALTY_FRACTION=250

# Optional: Token parameters
TOKEN_NAME=Denshokan
TOKEN_SYMBOL=DNSH
TOKEN_BASE_URI=https://api.denshokan.dev/token/

# Optional: Registry parameters
REGISTRY_NAME=DenshokanRegistry
REGISTRY_SYMBOL=DREG
REGISTRY_BASE_URI=https://api.denshokan.dev/registry/

# Optional: Use existing registry (skips registry deployment)
# GAME_REGISTRY_ADDRESS=0x456...

# Optional: Skip confirmation prompt
# SKIP_CONFIRMATION=true
