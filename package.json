{
  "name": "denshokan",
  "version": "0.1.0",
  "author": "Provable Games",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Provable-Games/denshokan.git"
  },
  "description": "Game token contracts and indexer for Starknet",
  "keywords": [
    "starknet",
    "cairo",
    "nft",
    "gaming",
    "indexer"
  ],
  "license": "MIT",
  "private": true,
  "scripts": {
    "build:contracts": "cd contracts && scarb build",
    "test:contracts": "cd contracts && snforge test",
    "coverage:contracts": "cd contracts && snforge test --coverage",
    "fmt:contracts": "cd contracts && scarb fmt -w",
    "build:indexer": "cd indexer && npm run build",
    "dev:indexer": "cd indexer && npm run dev",
    "build:api": "cd api && npm run build",
    "dev:api": "cd api && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build:client": "cd client && npm run build",
    "db:migrate": "cd indexer && npm run db:migrate",
    "db:generate": "cd indexer && npm run db:generate",
    "test": "npm run test:contracts",
    "build": "npm run build:contracts && npm run build:indexer && npm run build:api",
    "fmt": "npm run fmt:contracts"
  },
  "workspaces": [
    "indexer",
    "api",
    "client"
  ]
}
